# ==================== GÜVENLİK AYARLARI ====================
# Bu dosyayı .env olarak adlandırın ve değerleri değiştirin

# Flask secret key (rastgele bir string)
SECRET_KEY=buraya-rastgele-bir-anahtar-yazin

# Admin kimlik bilgileri
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=buraya-sifre-hash-yazin

# Production ayarları
FLASK_ENV=production
FLASK_DEBUG=0
